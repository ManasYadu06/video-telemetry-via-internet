# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Global Video Telemetry System
# ─────────────────────────────────────────────────────────────────────────────

# Environment / secrets — never commit real values
.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Logs
*.log
/tmp/

# Recordings
*.flv
*.mp4
*.h264
recordings/

# SSH keys
*.pem
*.ppk

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo